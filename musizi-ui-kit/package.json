{
  "name": "@northgreenug/musizi-ui-kit",
  "version": "0.9.6",
  "description": "Musizi University UI Component Library",
  "repository": {
    "type": "git",
    "url": "https://github.com/northgreenug/musizi-ui-kit.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/musizi-ui-kit.umd.js",
  "module": "./dist/musizi-ui-kit.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/musizi-ui-kit.es.js",
      "require": "./dist/musizi-ui-kit.umd.js"
    },
    "./dist/*": "./dist/*",
    "./theme.css": {
      "style": "./dist/theme.css",
      "default": "./dist/theme.css"
    },
    "./fonts.css": {
      "style": "./dist/fonts.css",
      "default": "./dist/fonts.css"
    },
    "./typography.css": {
      "style": "./dist/typography.css",
      "default": "./dist/typography.css"
    },
    "./styles.css": {
      "style": "./dist/musizi-ui-kit.css",
      "default": "./dist/musizi-ui-kit.css"
    },
    "./tailwind-source.css": {
      "style": "./dist/tailwind-source.css",
      "default": "./dist/tailwind-source.css"
    }
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.css",
    "dist/*.d.ts",
    "src/components/**/*.vue"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" && npm run copy-styles",
    "copy-styles": "node -e \"const fs = require('fs'); ['theme.css', '_theme.css', 'fonts.css', 'typography.css'].forEach(f => { const src = 'src/styles/' + f; if (fs.existsSync(src)) { fs.copyFileSync(src, 'dist/' + f); console.log('Copied ' + f + ' to dist/'); } else { console.error('Could not find ' + src); } })\"",
    "build:lib": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist && cp src/styles/fonts.css dist/fonts.css && cp src/styles/theme.css dist/theme.css && npx @tailwindcss/cli -i src/styles/typography.build.css -o dist/typography.css --minify && echo '@source \"../src/components\";' > dist/tailwind-source.css",
    "preview": "vite preview",
    "test:unit": "vitest",
    "prepare": "cypress install",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "storybook:css": "npx @tailwindcss/cli -i .storybook/storybook.css -o .storybook/storybook.compiled.css",
    "storybook:css:watch": "npx @tailwindcss/cli -i .storybook/storybook.css -o .storybook/storybook.compiled.css --watch",
    "storybook:dev": "storybook dev -p 6006",
    "storybook": "npm run storybook:css && run-p storybook:css:watch storybook:dev",
    "build-storybook": "npm run storybook:css && storybook build",
    "yalc:publish": "npm run build:lib && yalc publish",
    "yalc:push": "npm run build:lib && yalc push",
    "yalc:watch": "npm run build:lib && yalc push && chokidar \"src/**/*\" -c \"npm run build:lib && yalc push\"",
    "dev:lib": "npm run storybook:css && run-p storybook:css:watch storybook:dev yalc:watch"
  },
  "peerDependencies": {
    "tailwindcss": "^4.1.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-vue": "^8.6.0",
    "pinia": "^3.0.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.6",
    "@storybook/addon-essentials": "^8.6.9",
    "@storybook/addon-links": "^8.6.9",
    "@storybook/addon-onboarding": "^8.6.9",
    "@storybook/blocks": "^8.6.9",
    "@storybook/experimental-addon-test": "^8.6.9",
    "@storybook/test": "^8.6.9",
    "@storybook/vue3": "^8.6.9",
    "@storybook/vue3-vite": "^8.6.9",
    "@tailwindcss/nesting": "^0.0.0-insiders.565cd3e",
    "@tailwindcss/vite": "^4.1.18",
    "@tsconfig/node22": "^22.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "@vitest/browser": "^3.0.9",
    "@vitest/coverage-v8": "^3.0.9",
    "@vitest/eslint-plugin": "^1.1.36",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "chokidar-cli": "^3.0.0",
    "cypress": "^14.1.0",
    "eslint": "^9.21.0",
    "eslint-plugin-cypress": "^4.2.0",
    "eslint-plugin-storybook": "^0.12.0",
    "eslint-plugin-vue": "~10.0.0",
    "jiti": "^2.4.2",
    "jsdom": "^26.0.0",
    "npm-run-all2": "^7.0.2",
    "playwright": "^1.51.1",
    "prettier": "3.5.3",
    "start-server-and-test": "^2.0.10",
    "storybook": "^8.6.9",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.0",
    "vite": "^6.2.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vitest": "^3.0.9",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.8"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
