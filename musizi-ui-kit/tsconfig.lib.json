{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": false,
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*", "src/stories/**/*", "src/router/**/*", "src/views/**/*", "src/App.vue", "src/main.ts"]
}
